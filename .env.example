# Neon Postgres (primary database — required)
DATABASE_URL=

# Email (SMTP). Optional: Resend API in backlog for future.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Japanese with Avnish <noreply@japanesewithavnish.com>

# Razorpay (test mode). If unset, checkout uses manual UPI flow.
RAZORPAY_KEY_ID=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Keep disabled in production unless you intentionally expose /api/create-order for a custom flow.
ALLOW_GENERIC_RAZORPAY_ORDER_ENDPOINT=false

# Manual UPI (when Razorpay not configured). Default UPI ID: japanesewithavnish@ybl. Put QR at public/upi-qr.png.
NEXT_PUBLIC_UPI_ID=japanesewithavnish@ybl

# Stripe (feature flag OFF for MVP)
STRIPE_ENABLED=false
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin (comma-separated emails) + shared admin-panel password
ADMIN_EMAILS=your@email.com
ADMIN_PASSWORD=

# E2E testing (Phase 10): admin and test students — set for Browser MCP / Playwright e2e
# Admin must be in ADMIN_EMAILS; students must exist (sign up first or seed)
# E2E_BASE_URL=http://localhost:3001
# E2E_ADMIN_EMAIL=admin@example.com
# E2E_ADMIN_PASSWORD=your-admin-password
# E2E_STUDENT_1_EMAIL=student1@test.example.com
# E2E_STUDENT_1_PASSWORD=testpass123
# E2E_STUDENT_2_EMAIL=student2@test.example.com
# E2E_STUDENT_2_PASSWORD=testpass123
# E2E_STUDENT_3_EMAIL=student3@test.example.com
# E2E_STUDENT_3_PASSWORD=testpass123

# Session/access-token signing secret (required — app refuses to start without it; use a long random string)
ACCESS_TOKEN_SECRET=

# Site URL (for sitemap, emails, magic links)
NEXT_PUBLIC_SITE_URL=https://japanesewithavnish.com

# Cron (optional; for streak-reminder and sitemap-ping: ?key=CRON_SECRET)
# CRON_SECRET=

# Marketing, ads & analytics (optional; see docs/MARKETING_ANALYTICS_GUIDE.md)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_GTM_ID=
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=
# NEXT_PUBLIC_META_PIXEL_ID=
# NEXT_PUBLIC_MONETAG_TAG=

# Coming soon mode (true = show coming soon on home, false = full site)
COMING_SOON=true

# AI (optional — for admin content generation)
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
# For image generation: gemini-2.0-flash-preview-image-generation (default)
GEMINI_IMAGE_MODEL=
# OpenRouter (content/image generation for seeder scripts)
OPENROUTER_API_KEY=

# Dev only: LOCALTEST=true makes /api/learn/curriculum treat requests as
# logged-in without a session. Ignored in production builds — never set in prod.
# LOCALTEST=false

# Neon Auth (OAuth for Nihongo Navi — Google/Apple sign-in)
NEON_AUTH_URL=
NEON_AUTH_JWKS_URL=

# Cloudflare R2 (for AI-generated images and migrated storage)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_BUCKET_URL=

# Bundle Google Drive links (7 bundles — add your share links)
BUNDLE_FREE_STARTER_KIT_DRIVE_URL=
BUNDLE_MEGA_DRIVE_URL=
BUNDLE_N5_DRIVE_URL=
BUNDLE_N4_DRIVE_URL=
BUNDLE_N3_DRIVE_URL=
BUNDLE_N2_DRIVE_URL=
BUNDLE_N1_DRIVE_URL=
