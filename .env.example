# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email (SMTP). Optional: Resend API in backlog for future.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Japanese with Avnish <noreply@japanesewithavnish.com>

# Razorpay (test mode). If unset, checkout uses manual UPI flow.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Manual UPI (when Razorpay not configured). Default UPI ID: japanesewithavnish@ybl. Put QR at public/upi-qr.png.
NEXT_PUBLIC_UPI_ID=japanesewithavnish@ybl

# Stripe (feature flag OFF for MVP)
STRIPE_ENABLED=false
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin (comma-separated emails)
ADMIN_EMAILS=your@email.com

# Access links (per-order library link; use a long random string)
ACCESS_TOKEN_SECRET=

# Site URL (for sitemap, emails, magic links)
NEXT_PUBLIC_SITE_URL=https://japanesewithavnish.com

# Marketing, ads & analytics (optional; see docs/MARKETING_ANALYTICS_GUIDE.md)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_GTM_ID=
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=
# NEXT_PUBLIC_META_PIXEL_ID=

# Coming soon mode (true = show coming soon on home, false = full site)
COMING_SOON=true

# AI (optional — for admin content generation)
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
# For image generation: gemini-2.0-flash-preview-image-generation (default)
GEMINI_IMAGE_MODEL=

# Neon Postgres (optional; used when migrating off Supabase)
DATABASE_URL=

# Cloudflare R2 (for AI-generated images and migrated storage)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_BUCKET_URL=

# Optional: migrate only these Supabase Storage buckets to R2 (comma-separated; unset = all)
# SUPABASE_STORAGE_BUCKET=bundle-assets

# Bundle Google Drive links (7 bundles — add your share links)
BUNDLE_FREE_STARTER_KIT_DRIVE_URL=
BUNDLE_MEGA_DRIVE_URL=
BUNDLE_N5_DRIVE_URL=
BUNDLE_N4_DRIVE_URL=
BUNDLE_N3_DRIVE_URL=
BUNDLE_N2_DRIVE_URL=
BUNDLE_N1_DRIVE_URL=
